# ============================================================================
# AI TRAVEL PLANNER - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your API keys
# IMPORTANT: Never commit .env with real API keys!

# ============================================================================
# GOOGLE GEMINI API (Recommended - Fast & Cost-effective)
# Get key from: https://makersuite.google.com/app/apikey
# ============================================================================
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.0-flash

# ============================================================================
# OPENAI API (GPT-4, GPT-3.5-turbo)
# Get key from: https://platform.openai.com/api-keys
# ============================================================================
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4-turbo-preview
# OPENAI_ORG_ID=your_org_id_here  # Optional: If using organization

# ============================================================================
# ANTHROPIC CLAUDE API
# Get key from: https://console.anthropic.com/
# ============================================================================
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ============================================================================
# OPENROUTER API (Access to 100+ models)
# Get key from: https://openrouter.ai/keys
# ============================================================================
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=anthropic/claude-3-sonnet

# ============================================================================
# DEFAULT PROVIDER SELECTION
# Options: google, openai, anthropic, openrouter
# System will use this provider first, then fallback to others if needed
# ============================================================================
DEFAULT_LLM_PROVIDER=google

# ============================================================================
# REQUEST CONFIGURATION
# ============================================================================
REQUEST_TIMEOUT=30                   # API request timeout in seconds
MAX_RETRIES=3                        # Number of retry attempts on failure

# ============================================================================
# CACHING CONFIGURATION
# ============================================================================
ENABLE_CACHING=true                  # Enable caching for repeated requests
CACHE_TTL_SECONDS=3600               # Cache time-to-live (1 hour)

# ============================================================================
# LANGUAGE SETTINGS
# ============================================================================
LANGUAGE=en                          # Language for prompts (en, fr, es, etc.)

# ============================================================================
# DEBUGGING
# ============================================================================
LOG_LEVEL=INFO                       # DEBUG, INFO, WARNING, ERROR
DEBUG_MODE=false                     # Enable verbose logging
